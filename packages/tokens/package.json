{
  "name": "@design-token-forge/tokens",
  "version": "0.1.0",
  "description": "Token engine — schema parsing, resolution, and CSS/JSON/SCSS export",
  "type": "module",
  "main": "dist/index.css",
  "style": "dist/index.css",
  "exports": {
    ".": "./dist/index.css",
    "./primitives": "./dist/primitives.css",
    "./semantic": "./dist/semantic.css",
    "./surfaces": "./dist/surfaces.css",
    "./extras": "./dist/extras.css",
    "./tailwind-preset": {
      "import": "./dist/tailwind-preset.mjs",
      "require": "./dist/tailwind-preset.cjs"
    },
    "./tokens.dtcg.json": "./dist/tokens.dtcg.json",
    "./style-dictionary": "./dist/style-dictionary/tokens.json"
  },
  "files": [
    "dist"
  ],
  "sideEffects": ["**/*.css"],
  "keywords": ["design-tokens", "css-variables", "design-system", "w3c-dtcg", "tailwind", "style-dictionary"],
  "scripts": {
    "build": "node build.mjs",
    "prebuild": "rm -rf dist",
    "prepublishOnly": "npm run build",
    "test": "echo 'TODO: configure tests'"
  }
}
