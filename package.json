{
  "name": "figmaworkspace",
  "version": "1.0.0",
  "description": "This workspace is configured to use the Figma Model Context Protocol (MCP) server with VS Code.",
  "main": "index.js",
  "scripts": {
    "build": "cp src/socket.js dist/socket.js",
    "start": "node dist/socket.js",
    "dev": "node src/socket.js",
    "audit:naming": "node scripts/audit-naming.cjs",
    "audit:primitives": "node scripts/audit-primitive-aliases.cjs",
    "audit:token-drift": "node scripts/audit-token-drift.cjs",
    "audit:migration": "node scripts/migrate-v2/audit.cjs",
    "audit:gold": "bash scripts/audit-gold-standard.sh",
    "audit": "pnpm audit:naming && pnpm audit:primitives && pnpm audit:token-drift",
    "gate": "node scripts/gate-check.cjs",
    "gate:status": "node scripts/gate-check.cjs --all",
    "gate:regression": "node scripts/gate-check.cjs --regression",
    "audit:docs": "node scripts/audit-docs.cjs",
    "audit:docs:fix": "node scripts/audit-docs.cjs --fix",
    "gen:manifests": "node scripts/generate-token-manifest.cjs --all",
    "test:editor": "playwright test tests/editor-v2",
    "test:demo-qc": "playwright test tests/visual/components.spec.js tests/visual/demo-logical.spec.js tests/visual/demo-consistency.spec.js",
    "test:demo-qc:ci": "mkdir -p artifacts/demo-qc && PLAYWRIGHT_JSON_OUTPUT_DIR=artifacts/demo-qc PLAYWRIGHT_JSON_OUTPUT_NAME=results.json playwright test tests/visual/components.spec.js tests/visual/demo-logical.spec.js tests/visual/demo-consistency.spec.js --reporter=line,json",
    "test:demo-qc:report": "node scripts/summarize-demo-qc.cjs artifacts/demo-qc/results.json artifacts/demo-qc/summary.md",
    "build:react": "pnpm --filter @design-token-forge/react build",
    "export:dtcg": "node scripts/export-dtcg.cjs",
    "export:tailwind": "node scripts/export-tailwind.cjs",
    "export:style-dictionary": "node scripts/export-style-dictionary.cjs",
    "export:all": "node scripts/export-dtcg.cjs && node scripts/export-tailwind.cjs && node scripts/export-style-dictionary.cjs",
    "demo:react": "pnpm --filter @design-token-forge/react-demo dev",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.13.6",
    "express": "^5.2.1",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0"
  }
}
